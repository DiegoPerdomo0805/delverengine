{
  "version": 1,
  "globals": {
    "enemy_density_scale": 1.0,
    "item_density_scale": 1.0,
    "spawn_budget_factor": 1.0
  },
  "biomes": {
    "tech": {
      "enemy_weights": {
        "grunt": 1.0,
        "ranged": 0.8,
        "brute": 0.5
      },
      "item_weights": {
        "health_small": 1.2,
        "ammo_pistol": 1.1,
        "rare_core": 0.2
      },
      "caps": {
        "max_enemies_per_room": 6,
        "max_items_per_room": 3
      }
    }
  },
  "room_tags": {
    "treasure": {
      "item_density_scale": 2.0,
      "enemy_density_scale": 0.6
    },
    "gauntlet": {
      "enemy_density_scale": 1.6,
      "item_density_scale": 0.7
    }
  },
  "filters": [
    { "if": { "player_archetype": "Knight" }, "then": {
      "enemy_weights": { "brute": 0.35, "ranged": 1.1 },
      "item_weights":  { "shield": 1.4, "mana_small": 0.7 }
    }},
    { "if": { "player_archetype": "SpellSniper" }, "then": {
      "enemy_weights": { "ranged": 0.6, "grunt": 1.1 },
      "item_weights":  { "mana_small": 1.3, "ammo_pistol": 0.6 }
    }}
  ]
}
